# Copy this file to .env and fill in the keys you have.
# .env is gitignored - never commit real keys.

# Required for --provider groq (the default everywhere in this project).
# Free tier: https://console.groq.com
GROQ_API_KEY=

# Required only if you pass --provider anthropic / --attacker-provider anthropic
# explicitly (e.g. once Anthropic credits are available).
ANTHROPIC_API_KEY=

# Optional overrides - defaults are set in victim/agent.py
# ANTHROPIC_MODEL=claude-opus-4-8
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional overrides for the attacker-LLM - defaults are set in attacker/llm_client.py
# ATTACKER_MODEL_ANTHROPIC=claude-sonnet-5
# ATTACKER_MODEL_GROQ=llama-3.3-70b-versatile
